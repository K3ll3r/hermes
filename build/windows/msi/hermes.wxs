<?xml version="1.0" encoding="UTF-8"?>
<!-- Build: wix build build/windows/msi/hermes.wxs -arch x64 -d Version=0.0.5 -d StagingDir=build/bin -o dist/hermes.msi -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Hermes"
    Manufacturer="TsekNet"
    Version="$(var.Version)"
    UpgradeCode="B7E8A1C2-9D4E-4F5A-8B3C-1E2D3F4A5B6C"
    Scope="perMachine">

    <MajorUpgrade AllowDowngrades="yes" />

    <MediaTemplate EmbedCab="yes" />

    <Icon Id="HermesIcon" SourceFile="$(var.StagingDir)/hermes.exe" />
    <Property Id="ARPPRODUCTICON" Value="HermesIcon" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="HermesDir" Name="Hermes">
        <Component Id="HermesExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
          <File Id="HermesExeFile" Source="$(var.StagingDir)/hermes.exe" KeyPath="yes" />
        </Component>
        <Component Id="HermesAutostart" Guid="D4E5F6A7-B890-1234-CDEF-567890ABCDEF">
          <RegistryValue Root="HKLM" Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run" Name="Hermes" Value="&quot;[HermesDir]hermes.exe&quot; serve" Type="string" KeyPath="yes" />
        </Component>
        <Component Id="CleanupDir" Guid="E5F6A7B8-C901-2345-DEF0-678901BCDEF0">
          <RemoveFolder Id="RemoveHermesDir" On="uninstall" />
          <RegistryValue Root="HKLM" Key="SOFTWARE\TsekNet\Hermes" Name="Cleanup" Value="1" Type="integer" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <CustomAction Id="StopHermes" FileRef="HermesExeFile"
      ExeCommand="stop" Execute="deferred" Impersonate="no" Return="ignore" />

    <CustomAction Id="InstallHook" FileRef="HermesExeFile"
      ExeCommand="install" Execute="deferred" Impersonate="no" Return="ignore" />

    <CustomAction Id="UninstallHook" FileRef="HermesExeFile"
      ExeCommand="uninstall" Execute="deferred" Impersonate="no" Return="ignore" />

    <CustomAction Id="StartDaemon" FileRef="HermesExeFile"
      ExeCommand="serve" Execute="immediate" Impersonate="yes" Return="asyncNoWait" />

    <InstallExecuteSequence>
      <Custom Action="StopHermes" After="InstallInitialize" Condition="REMOVE=&quot;ALL&quot; OR UPGRADINGPRODUCTCODE" />
      <Custom Action="InstallHook" After="InstallFiles" Condition="NOT Installed OR UPGRADINGPRODUCTCODE" />
      <Custom Action="UninstallHook" After="InstallFiles" Condition="REMOVE=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
      <Custom Action="StartDaemon" After="InstallFinalize" Condition="NOT REMOVE" />
    </InstallExecuteSequence>

    <Feature Id="ProductFeature" Title="Hermes" Level="1">
      <ComponentRef Id="HermesExe" />
      <ComponentRef Id="HermesAutostart" />
      <ComponentRef Id="CleanupDir" />
    </Feature>
  </Package>
</Wix>
